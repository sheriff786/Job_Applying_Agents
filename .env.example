# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Database (PostgreSQL + pgvector)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/job_agent
DATABASE_URL_SYNC=postgresql://postgres:password@localhost:5432/job_agent

# Redis (for Celery)
REDIS_URL=redis://localhost:6379/0

# Job Board APIs
GREENHOUSE_API_TOKEN=
LEVER_API_KEY=
ASHBY_API_KEY=

# LinkedIn (manual export path)
LINKEDIN_EXPORT_DIR=./data/linkedin_exports

# Google Drive (for resume template storage)
GOOGLE_CREDENTIALS_FILE=./credentials/google_credentials.json
RESUME_TEMPLATE_DRIVE_ID=

# Gmail MCP
GMAIL_CREDENTIALS_FILE=./credentials/gmail_credentials.json

# Calendar MCP
CALENDAR_CREDENTIALS_FILE=./credentials/calendar_credentials.json

# Agent Configuration
FIT_SCORE_THRESHOLD=0.70
TARGET_LOCATIONS=US,UK,Canada,Germany,Netherlands,Singapore,Australia
EXCLUDED_LOCATIONS=India
TARGET_COMPANIES_TYPE=MAANG,FAANG,product-based
SENIORITY_LEVELS=mid,senior,staff

# Resume
RESUME_TEMPLATE_PATH=./data/resume_template.docx
RESUME_OUTPUT_DIR=./data/generated_resumes
